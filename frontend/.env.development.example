# Local development starting point. Copy to `.env` (or `.env.development`,
# which Vite auto-loads for `npm run dev` and takes precedence over `.env`).
# See .env.example for what every variable means.

# Mock mode is the default for local dev — no backend needed to work on
# the frontend at all.
VITE_USE_MOCK=true

# Only relevant if you flip VITE_USE_MOCK=false to test against a locally
# running backend (see backend/README or docs/onboarding.md).
VITE_API_BASE_URL=/api

# Get your own free key so the Contact form works locally:
# https://web3forms.com
VITE_WEB3FORMS_ACCESS_KEY=

# Get your own free username so the Newsletter form works locally:
# https://buttondown.com/signup
VITE_BUTTONDOWN_USERNAME=

VITE_DEMO_MODE=true
