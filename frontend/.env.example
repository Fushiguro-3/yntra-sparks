# Yntra Sparks frontend — environment variables reference.
#
# Copy this file to `.env` for local development (`.env` is gitignored —
# never commit real secrets). Vite only exposes variables prefixed with
# VITE_ to browser code; everything here is bundled into the client build,
# so nothing in this file should ever be a private/secret API key.
#
# For environment-specific starting points see:
#   .env.development.example  — local dev against mock data (default)
#   .env.production.example   — a real deployment (Vercel, etc.)

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------

# Master switch for the mock API layer. true = all data is served from
# in-memory mocks in src/api/mock/*, no backend required. false = every
# service in src/api/*Service.js calls the real backend via axios (src/api/http.js).
# Defaults to true when unset — see src/config.js.
VITE_USE_MOCK=true

# Base URL the axios client (src/api/http.js) sends requests to when
# VITE_USE_MOCK=false. Ignored in mock mode. Defaults to "/api" (same-origin,
# relies on a dev proxy or reverse proxy in front of the backend).
VITE_API_BASE_URL=/api

# ---------------------------------------------------------------------------
# Web3Forms — public Contact page (src/views/public/ContactView.vue)
# ---------------------------------------------------------------------------
# Free form-relay service: the public Contact form POSTs directly to
# Web3Forms, which emails the submission to the inbox configured on the
# Web3Forms account. No backend involved.
#
# Get a key: https://web3forms.com -> "Create Access Key" (enter the
# destination email address, no account/signup required for a single key).
# The key is a per-form routing token, not a traditional secret, but it
# still must not be hardcoded in source — set it here instead.
VITE_WEB3FORMS_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Buttondown — public Newsletter signup (footer + src/components/public/NewsletterForm.vue)
# ---------------------------------------------------------------------------
# Buttondown's public embed-subscribe endpoint is used (no API key needed
# or wanted in frontend code — never put a Buttondown API key here).
# This is just your Buttondown newsletter's username, used to build the
# public subscribe URL: https://buttondown.com/api/emails/embed-subscribe/<username>
#
# Create a free account: https://buttondown.com/signup (free for your
# first 100 subscribers). Your username is shown in Settings -> General,
# and the exact current embed snippet/URL is shown under
# Settings -> Grow -> "Embed a subscribe form" — verify it matches the
# implementation in src/services/newsletterService.js before going live.
# Double opt-in confirmation emails are ON by default on every Buttondown
# newsletter, so subscribers automatically receive a confirmation email —
# no extra setup needed for that.
VITE_BUTTONDOWN_USERNAME=

# ---------------------------------------------------------------------------
# Demo mode
# ---------------------------------------------------------------------------
# Shows a small "Demo Mode" badge in the Super Admin / Principal / Teacher
# dashboard headers. Defaults to the value of VITE_USE_MOCK if unset —
# override independently only if you need the badge shown/hidden against a
# real backend (e.g. a staging deploy seeded with demo data).
# VITE_DEMO_MODE=true

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
# Both default to true (features are fully functional today). Set to
# false to hide them in a given environment without a code change. See
# docs/requirements.md "Out of Scope / Future Enhancements" for context.
# VITE_FEATURE_KIT_PRICING=true
# VITE_FEATURE_KIT_MANUALS=true

# ---------------------------------------------------------------------------
# Future integrations (not wired to any code yet — reserved placeholders)
# ---------------------------------------------------------------------------
# VITE_ANALYTICS_ID=
# VITE_ERROR_TRACKING_DSN=
