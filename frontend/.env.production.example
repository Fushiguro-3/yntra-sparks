# Production deployment starting point (e.g. Vercel project env vars).
# Copy the values you need into your hosting provider's environment
# variable settings — do not commit a real `.env.production` file.
# See .env.example for what every variable means.

# Flip to false only once the backend team has confirmed every endpoint
# listed in docs/frontend-api-dependencies.md is implemented and reachable.
VITE_USE_MOCK=true

# Real backend origin, once VITE_USE_MOCK=false.
VITE_API_BASE_URL=https://api.yntrasparks.com

# Production Web3Forms access key (create at https://web3forms.com,
# pointed at whichever inbox should receive live enquiries).
VITE_WEB3FORMS_ACCESS_KEY=

# Production Buttondown newsletter username (https://buttondown.com/signup).
VITE_BUTTONDOWN_USERNAME=

# Turn the demo badge off for a real production deployment.
VITE_DEMO_MODE=false

VITE_FEATURE_KIT_PRICING=true
VITE_FEATURE_KIT_MANUALS=true

VITE_ANALYTICS_ID=
VITE_ERROR_TRACKING_DSN=
